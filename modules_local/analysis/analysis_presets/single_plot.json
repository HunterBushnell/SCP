{
  "title": "single_plot",
  "defaults": {
    "trial_idx": 0,
    "top_input_groups": [],
    "raster_input_groups": ["bg_inh"],
    "top_input_mode": "average",
    "top_layout": "overlay",
    "top_fill_under": false,
    "top_fill_alpha": 0.28,

    "input_bin_ms": 5.0,
    "input_smooth_ms": 25.0,
    "input_source": "stats",
